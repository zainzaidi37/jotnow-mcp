{
  "name": "jotnow",
  "version": "0.2.0",
  "packageManager": "pnpm@9.15.9",
  "description": "Jot notes from Claude Code / Codex to jotnow — MCP server and CLI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zainzaidi37/jotnow-mcp.git"
  },
  "homepage": "https://jotnow.dev",
  "bugs": {
    "url": "https://github.com/zainzaidi37/jotnow-mcp/issues"
  },
  "type": "module",
  "bin": {
    "jotnow": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
